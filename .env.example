# ============================================================
# Project Planner — Environment Variables
# Copy this file to `.env` and fill in the values.
# ============================================================

# ----- Database (PostgreSQL) -----
# Local docker-compose default:
DATABASE_URL="postgresql://planner:planner@localhost:5432/planner?schema=public"

# ----- Auth.js (NextAuth v5) -----
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"
# Base URL of the app (no trailing slash). Required in production.
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# ----- Microsoft Entra ID (Azure AD) SSO -----
# From your App Registration in the Azure Portal.
AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
# Your tenant ID (or "common" for multi-tenant). Single-tenant recommended for corporate.
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=""
# Restrict logins to a single tenant (recommended for a company-only app):
ALLOWED_TENANT_ID=""
# Comma-separated list of email domains allowed to sign in, e.g. "contoso.com"
ALLOWED_EMAIL_DOMAINS=""

# ----- Dev login fallback -----
# Set to "true" to enable the local email/password dev login (NEVER in production).
ENABLE_DEV_LOGIN="true"

# ----- Microsoft Graph (email notifications + OneDrive/SharePoint) -----
# Uses the same App Registration. Requires Mail.Send, Files.ReadWrite.All,
# Sites.ReadWrite.All application permissions (admin consent).
GRAPH_TENANT_ID=""
GRAPH_CLIENT_ID=""
GRAPH_CLIENT_SECRET=""
# The user/mailbox to send notification emails from (UPN), e.g. notifications@contoso.com
GRAPH_SENDER_UPN=""
# SharePoint site id or OneDrive drive id used for file storage (optional).
GRAPH_DRIVE_ID=""

# ----- Feature flags -----
# When Graph creds are absent, files are stored locally under /uploads.
FILE_STORAGE_DRIVER="local"   # "local" | "graph"
EMAIL_DRIVER="console"        # "console" | "graph"
