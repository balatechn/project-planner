// ============================================================
// Sharepoint — Prisma schema
// PostgreSQL. Covers auth, RBAC, projects, tasks, collaboration,
// notifications, templates, audit logging and reporting entities.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------
// Enums
// ----------------------------------------------------------------

enum Role {
  ADMIN
  PROJECT_MANAGER
  TEAM_MEMBER
  VIEWER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
  CANCELLED
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  DELAYED
}

enum DependencyType {
  FINISH_TO_START
  START_TO_START
  FINISH_TO_FINISH
  START_TO_FINISH
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_DUE_SOON
  TASK_OVERDUE
  TASK_COMMENT
  PROJECT_STATUS
  MENTION
  PROJECT_INVITE
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum LeaveType {
  VACATION
  SICK
  PERSONAL
  PUBLIC_HOLIDAY
  OTHER
}

enum SprintStatus {
  PLANNING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskStatus {
  OPEN
  MITIGATED
  ACCEPTED
  CLOSED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AnnouncementType {
  INFO
  SUCCESS
  WARNING
  URGENT
}

enum RoomBookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

// ----------------------------------------------------------------
// Auth.js models (Account / Session / VerificationToken)
// ----------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ----------------------------------------------------------------
// Core: User
// ----------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // dev-login only; never used with Entra SSO
  role          Role      @default(TEAM_MEMBER)
  jobTitle      String?
  department    String?
  // Group company the user belongs to (e.g. National Infrabuild)
  entity        String?
  // Office location (e.g. Chennai, Mumbai)
  location      String?
  // Updated on every successful sign-in
  lastLoginAt   DateTime?
  // Microsoft Entra object id, for Graph correlation
  entraOid      String?   @unique
  isActive      Boolean   @default(true)
  // Capacity in hours/week used by workload reports
  weeklyCapacity Int      @default(40)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  ownedProjects     Project[]        @relation("ProjectOwner")
  managedProjects   Project[]        @relation("ProjectManager")
  memberships       ProjectMember[]
  createdTasks      Task[]           @relation("TaskCreatedBy")
  assignedTasks     TaskAssignee[]
  comments          Comment[]
  attachments       Attachment[]
  activities        Activity[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  leaveEntries      LeaveEntry[]
  discussionPosts   DiscussionPost[]
  timeLogs          TimeLog[]
  approvals         TaskApproval[]
  announcements     Announcement[]
  trainingVideos    TrainingVideo[]
  organizedBookings RoomBooking[]  @relation("RoomBookingOrganizer")
  bookedForMeetings RoomBooking[]  @relation("RoomBookingFor")
  driveAccess       DriveAccess[]
  spreadsheets      Spreadsheet[]
  sharedWithMe      SpreadsheetShare[] @relation("SharedWithMe")
  sharedByMe        SpreadsheetShare[] @relation("SharedByMe")

  @@index([department])
  @@index([role])
}

// ----------------------------------------------------------------
// Project
// ----------------------------------------------------------------

model Project {
  id               String        @id @default(cuid())
  name             String
  key              String        @unique // short code e.g. "MKT-2026"
  description      String?       @db.Text
  entity           String?       // business entity / division
  department       String?
  location         String?       // office location (from Location master)
  programType      String?       // program type (from ProgramType master)
  priority         Priority      @default(MEDIUM)
  status           ProjectStatus @default(PLANNING)
  startDate        DateTime?
  endDate          DateTime?
  budget           Decimal?      @db.Decimal(14, 2)
  budgetActual     Decimal?      @db.Decimal(14, 2)
  currency         String        @default("USD")
  color            String        @default("#f59e0b")
  isArchived       Boolean       @default(false)
  archivedAt       DateTime?
  published        Boolean       @default(false)
  // Soft delete — set means "in recycle bin"; purged permanently after 30 days
  deletedAt        DateTime?
  ownerId          String
  projectManagerId String?       // designated PM (may differ from owner)
  templateId       String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  owner          User             @relation("ProjectOwner", fields: [ownerId], references: [id])
  projectManager User?            @relation("ProjectManager", fields: [projectManagerId], references: [id])
  template       ProjectTemplate? @relation(fields: [templateId], references: [id])
  members        ProjectMember[]
  tasks          Task[]
  discussions    DiscussionPost[]
  activities     Activity[]
  sprints        Sprint[]
  risks          Risk[]
  meetingNotes   MeetingNote[]
  customFields   CustomFieldValue[]

  @@index([ownerId])
  @@index([projectManagerId])
  @@index([status])
  @@index([department])
  @@index([isArchived])
  @@index([deletedAt])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  // Role scoped to this project (overrides nothing global, used for per-project access)
  role      Role     @default(TEAM_MEMBER)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

// ----------------------------------------------------------------
// Task & Subtask (self-referential parent/child)
// ----------------------------------------------------------------

model Task {
  id             String     @id @default(cuid())
  projectId      String
  sprintId       String?    // assigned sprint (nullable = backlog)
  parentId       String?    // null => top-level task; set => subtask
  wbsNumber      String?    // WBS e.g. "1.2.3"
  title          String
  description    String?    @db.Text
  status         TaskStatus @default(NOT_STARTED)
  priority       Priority   @default(MEDIUM)
  startDate      DateTime?
  dueDate        DateTime?
  completedAt    DateTime?
  // 0-100 percentage complete
  progress       Int        @default(0)
  estimatedHours Float?
  actualHours    Float?
  // Milestone flag — renders as diamond on Gantt
  isMilestone    Boolean    @default(false)
  // Baseline dates for plan-vs-actual comparison
  baselineStart  DateTime?
  baselineEnd    DateTime?
  // accent colour for the task row (optional hex, e.g. "#ef4444")
  color          String?
  // ordering within a status column / list
  orderIndex     Int        @default(0)
  // Soft delete — set means "in recycle bin"; purged permanently after 30 days
  deletedAt      DateTime?
  createdById    String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint       Sprint?        @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  parent       Task?          @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks     Task[]         @relation("Subtasks")
  createdBy    User           @relation("TaskCreatedBy", fields: [createdById], references: [id])
  assignees    TaskAssignee[]
  comments     Comment[]
  attachments  Attachment[]
  reminders    Reminder[]
  checklistItems ChecklistItem[]
  labels       TaskLabelAssignment[]
  timeLogs     TimeLog[]
  approval     TaskApproval?

  // dependency edges
  dependsOn      TaskDependency[] @relation("DependentTask")
  dependedOnBy   TaskDependency[] @relation("PrerequisiteTask")

  // recurrence template
  recurrence RecurrenceRule?

  @@index([projectId])
  @@index([projectId, status]) // composite for workspace task loading
  @@index([sprintId])
  @@index([parentId])
  @@index([status])
  @@index([dueDate])
  @@index([updatedAt])
  @@index([deletedAt])
}

model TaskAssignee {
  id         String   @id @default(cuid())
  taskId     String
  userId     String
  assignedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
}

model TaskDependency {
  id             String         @id @default(cuid())
  // the task that depends on the prerequisite
  taskId         String
  // the prerequisite that must be satisfied first
  prerequisiteId String
  type           DependencyType @default(FINISH_TO_START)
  createdAt      DateTime       @default(now())

  task         Task @relation("DependentTask", fields: [taskId], references: [id], onDelete: Cascade)
  prerequisite Task @relation("PrerequisiteTask", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@unique([taskId, prerequisiteId])
  @@index([prerequisiteId])
}

model RecurrenceRule {
  id         String              @id @default(cuid())
  taskId     String              @unique
  frequency  RecurrenceFrequency
  interval   Int                 @default(1) // every N units
  // bitmask or csv of weekdays for WEEKLY (0=Sun..6=Sat)
  byWeekday  String?
  endDate    DateTime?
  count      Int? // max occurrences
  nextRunAt  DateTime?
  createdAt  DateTime            @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Reminder {
  id        String   @id @default(cuid())
  taskId    String
  remindAt  DateTime
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([remindAt, sent])
}

// ----------------------------------------------------------------
// Collaboration: comments, attachments, discussions, activity
// ----------------------------------------------------------------

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  body      String   @db.Text
  // user ids mentioned via @mention, csv
  mentions  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Attachment {
  id          String   @id @default(cuid())
  taskId      String?
  uploadedById String
  fileName    String
  mimeType    String
  size        Int
  // local path or Graph driveItem url
  storageDriver String @default("local") // "local" | "graph"
  url         String   @db.Text
  // Graph driveItem id for OneDrive/SharePoint files
  driveItemId String?
  createdAt   DateTime @default(now())

  task       Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User  @relation(fields: [uploadedById], references: [id])

  @@index([taskId])
}

model DiscussionPost {
  id        String   @id @default(cuid())
  projectId String
  authorId  String
  body      String   @db.Text
  parentId  String? // threaded replies
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  DiscussionPost?  @relation("Thread", fields: [parentId], references: [id], onDelete: Cascade)
  replies DiscussionPost[] @relation("Thread")

  @@index([projectId])
}

model Activity {
  id        String   @id @default(cuid())
  projectId String?
  userId    String
  // e.g. "task.created", "project.status_changed", "comment.added"
  action    String
  // arbitrary JSON metadata describing the change
  metadata  Json?
  entityType String? // "task" | "project" | "comment" ...
  entityId   String?
  createdAt DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
}

// ----------------------------------------------------------------
// Notifications
// ----------------------------------------------------------------

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?          @db.Text
  // deep link target, e.g. /projects/abc/tasks/xyz
  link      String?
  isRead    Boolean          @default(false)
  // whether an email was dispatched via Graph
  emailSent Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

// ----------------------------------------------------------------
// Templates
// ----------------------------------------------------------------

model ProjectTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  department  String?
  // serialized task tree + defaults
  blueprint   Json
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects Project[]
}

// ----------------------------------------------------------------
// Leave calendar / capacity planning
// ----------------------------------------------------------------

model LeaveEntry {
  id        String    @id @default(cuid())
  userId    String
  type      LeaveType @default(VACATION)
  startDate DateTime
  endDate   DateTime
  note      String?
  approved  Boolean   @default(false)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startDate, endDate])
}

// ----------------------------------------------------------------
// Audit log (security / compliance)
// ----------------------------------------------------------------

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String // e.g. "auth.login", "project.delete"
  entityType String?
  entityId   String?
  ipAddress  String?
  userAgent  String?  @db.Text
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ----------------------------------------------------------------
// Checklist items (sub-items inside a task)
// ----------------------------------------------------------------

model ChecklistItem {
  id          String   @id @default(cuid())
  taskId      String
  title       String
  isCompleted Boolean  @default(false)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// ----------------------------------------------------------------
// Labels / Tags
// ----------------------------------------------------------------

model TaskLabel {
  id        String   @id @default(cuid())
  projectId String?  // null = global label
  name      String
  color     String   @default("#f59e0b")
  createdAt DateTime @default(now())

  assignments TaskLabelAssignment[]

  @@index([projectId])
}

model TaskLabelAssignment {
  id        String @id @default(cuid())
  taskId    String
  labelId   String

  task  Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label TaskLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
  @@index([labelId])
}

// ----------------------------------------------------------------
// Time Logging
// ----------------------------------------------------------------

model TimeLog {
  id          String   @id @default(cuid())
  taskId      String
  userId      String
  hours       Float
  logDate     DateTime @default(now())
  description String?
  createdAt   DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

// ----------------------------------------------------------------
// Sprints
// ----------------------------------------------------------------

model Sprint {
  id          String       @id @default(cuid())
  projectId   String
  name        String
  goal        String?      @db.Text
  status      SprintStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  orderIndex  Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId])
  @@index([status])
}

// ----------------------------------------------------------------
// Risk Register
// ----------------------------------------------------------------

model Risk {
  id          String     @id @default(cuid())
  projectId   String
  title       String
  description String?    @db.Text
  level       RiskLevel  @default(MEDIUM)
  probability Int        @default(3) // 1-5 scale
  impact      Int        @default(3) // 1-5 scale
  status      RiskStatus @default(OPEN)
  mitigation  String?    @db.Text
  ownerId     String?
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

// ----------------------------------------------------------------
// Meeting Notes
// ----------------------------------------------------------------

model MeetingNote {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  agenda      String?  @db.Text
  notes       String?  @db.Text
  actionItems Json?    // [{text, assigneeId, dueDate, done}]
  attendees   String?  // comma-separated user ids
  meetingDate DateTime
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([meetingDate])
}

// ----------------------------------------------------------------
// Task Approval Workflow
// ----------------------------------------------------------------

model TaskApproval {
  id          String         @id @default(cuid())
  taskId      String         @unique
  approverId  String
  status      ApprovalStatus @default(PENDING)
  comment     String?        @db.Text
  requestedAt DateTime       @default(now())
  resolvedAt  DateTime?

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  approver User @relation(fields: [approverId], references: [id])

  @@index([approverId])
  @@index([status])
}

// ----------------------------------------------------------------
// Custom Fields
// ----------------------------------------------------------------

model CustomFieldDefinition {
  id          String   @id @default(cuid())
  projectId   String?  // null = global
  name        String
  fieldType   String   // "text" | "number" | "date" | "select" | "checkbox"
  options     Json?    // for select fields
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  values CustomFieldValue[]

  @@index([projectId])
}

// ----------------------------------------------------------------
// Announcements (admin broadcasts to all users)
// ----------------------------------------------------------------

model Announcement {
  id        String           @id @default(cuid())
  title     String
  body      String           @db.Text
  type      AnnouncementType @default(INFO)
  isActive  Boolean          @default(true)
  isPinned  Boolean          @default(false)
  expiresAt DateTime?
  authorId  String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([isActive, isPinned])
  @@index([createdAt])
}

// ----------------------------------------------------------------
// Training Videos
// ----------------------------------------------------------------

model TrainingVideo {
  id           String   @id @default(cuid())
  title        String
  description  String?  @db.Text
  videoUrl     String   // YouTube / Vimeo URL or direct MP4
  thumbnail    String?
  category     String?
  duration     String?  // display string e.g. "12:34"
  isPublished  Boolean  @default(false)
  orderIndex   Int      @default(0)
  uploadedById String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@index([isPublished])
  @@index([category])
}

model CustomFieldValue {
  id          String   @id @default(cuid())
  projectId   String
  fieldDefId  String
  value       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project  Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fieldDef CustomFieldDefinition @relation(fields: [fieldDefId], references: [id], onDelete: Cascade)

  @@unique([projectId, fieldDefId])
  @@index([fieldDefId])
}

// ----------------------------------------------------------------
// Meeting Room Booking
// ----------------------------------------------------------------

model Room {
  id           String   @id @default(cuid())
  name         String
  floor        String?
  building     String?
  capacity     Int      @default(4)
  amenities    String[] // e.g. ["projector","whiteboard","videoConf","ac","phone"]
  description  String?
  photoUrl     String?
  contactEmail String?  // shared mailbox — receives booking notifications
  isActive     Boolean  @default(true)
  color        String   @default("#3b82f6")
  orderIndex   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bookings RoomBooking[]

  @@index([isActive])
}

model RoomBooking {
  id               String            @id @default(cuid())
  roomId           String
  organizerId      String
  bookedForId      String?           // book on behalf of another user
  title            String
  description      String?           @db.Text
  startTime        DateTime
  endTime          DateTime
  attendeeIds      String[]          // internal user ids
  guestEmails      String[]          // external vendor / guest email addresses
  // Teams / Graph integration
  teamsJoinUrl     String?
  teamsMeetingId   String?
  teamsEventId     String?
  // Recurring
  isRecurring      Boolean           @default(false)
  recurringType    String?           // "daily" | "weekly" | "monthly"
  recurringDays    String?           // csv weekday nums "1,3,5"
  recurringEnd     DateTime?
  recurringGroupId String?
  status           RoomBookingStatus @default(CONFIRMED)
  reminderSent     Boolean           @default(false)
  meetingNotes     String?           @db.Text
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  room      Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  organizer User  @relation("RoomBookingOrganizer", fields: [organizerId], references: [id])
  bookedFor User? @relation("RoomBookingFor", fields: [bookedForId], references: [id])

  @@index([roomId])
  @@index([organizerId])
  @@index([startTime, endTime])
  @@index([status])
  @@index([recurringGroupId])
}

// ── Master data (admin-managed dropdown values) ─────────────────────────
enum MasterType {
  ENTITY
  LOCATION
  DEPARTMENT
  DESIGNATION
  PROGRAM_TYPE
}

model MasterOption {
  id         String     @id @default(cuid())
  type       MasterType
  name       String
  isActive   Boolean    @default(true)
  orderIndex Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([type, name])
  @@index([type, isActive])
}

// ── Common Drive — OneDrive folder access control ───────────────────────────
model DriveAccess {
  id         String   @id @default(cuid())
  folderPath String   // "/" = root, "/Accounts Common" = specific folder
  userId     String?  // null = role-level grant
  role       Role?    // null = user-level grant
  canWrite   Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([folderPath])
  @@index([userId])
  @@index([role])
}

// Company holiday calendar (admin-managed)
model Holiday {
  id        String   @id @default(cuid())
  date      DateTime @unique
  name      String
  createdAt DateTime @default(now())
}

enum SharePermission {
  VIEW
  EDIT
}

// ── Sheets (Excel-like spreadsheet workspace, multiple per user) ─────────────
model Spreadsheet {
  id        String             @id @default(cuid())
  name      String             @default("My Spreadsheet")
  ownerId   String
  owner     User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tabs      SpreadsheetTab[]
  shares    SpreadsheetShare[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([ownerId])
}

model SpreadsheetShare {
  id            String          @id @default(cuid())
  spreadsheetId String
  spreadsheet   Spreadsheet     @relation(fields: [spreadsheetId], references: [id], onDelete: Cascade)
  sharedWithId  String
  sharedWith    User            @relation("SharedWithMe", fields: [sharedWithId], references: [id], onDelete: Cascade)
  sharedById    String
  sharedBy      User            @relation("SharedByMe",   fields: [sharedById],   references: [id], onDelete: Cascade)
  permission    SharePermission @default(VIEW)
  createdAt     DateTime        @default(now())

  @@unique([spreadsheetId, sharedWithId])
  @@index([sharedWithId])
  @@index([spreadsheetId])
}

model SpreadsheetTab {
  id            String                @id @default(cuid())
  spreadsheetId String
  spreadsheet   Spreadsheet           @relation(fields: [spreadsheetId], references: [id], onDelete: Cascade)
  name          String                @default("Sheet1")
  orderIndex    Int                   @default(0)
  cells         Json                  @default("{}")
  colWidths     Json                  @default("{}")
  history       SpreadsheetHistory[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([spreadsheetId])
}

model SpreadsheetHistory {
  id        String         @id @default(cuid())
  tabId     String
  tab       SpreadsheetTab @relation(fields: [tabId], references: [id], onDelete: Cascade)
  cells     Json           @default("{}")
  colWidths Json           @default("{}")
  label     String?
  createdAt DateTime       @default(now())

  @@index([tabId, createdAt(sort: Desc)])
}
